    },
    {
      "name": "commit_trailer_with_connection_string",
      "content_parts": ["Memory-Decision: migrated to postgres://admin:", "hunter2placeholder", "@db.internal:5432/app for prod"],
      "must_not_contain_parts": [["admin:", "hunter2placeholder"]]
    },
    {
      "name": "log_with_slack_token",
      "content_parts": ["notify failed for xoxb-", "1234567890-", "abcdefghijklmnop: channel archived"],
